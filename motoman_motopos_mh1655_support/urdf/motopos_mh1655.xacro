<?xml version="1.0" ?>
<robot name="motoman_motopos_mh1655" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="$(find motoman_motopos_mh1655_support)/urdf/motopos_mh1655_macro.xacro" />
  <xacro:arg name="kinematic_offsets_file" default="$(find motoman_motopos_mh1655_support)/config/default_kinematic_offsets.yaml"/>
  <xacro:arg name="use_pedestal" default="false"/>
  <xacro:motoman_motopos_mh1655 prefix="" use_pedestal="$(arg use_pedestal)" kinematic_offsets="${xacro.load_yaml('$(arg kinematic_offsets_file)')['kinematic_offsets']}"/>
</robot>

<?xml version="1.0" ?>
<robot name="motoman_ar2010" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="$(find motoman_ar2010_support)/urdf/ar2010_macro.xacro" />
  <xacro:arg name="kinematic_offsets_file" default="$(find motoman_ar2010_support)/config/default_kinematic_offsets.yaml"/>
  <xacro:motoman_ar2010 prefix="" kinematic_offsets="${xacro.load_yaml('$(arg kinematic_offsets_file)')['kinematic_offsets']}"/>
</robot>

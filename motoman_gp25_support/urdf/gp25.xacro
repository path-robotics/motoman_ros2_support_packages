<?xml version="1.0" ?>

<robot name="motoman_gp25" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="$(find motoman_gp25_support)/urdf/gp25_macro.xacro" />
  <xacro:arg name="kinematic_offsets_file" default="$(find motoman_gp25_support)/config/default_kinematic_offsets.yaml"/>
  <xacro:motoman_gp25 prefix="" kinematic_offsets="${xacro.load_yaml('$(arg kinematic_offsets_file)')['kinematic_offsets']}"/>
</robot>
